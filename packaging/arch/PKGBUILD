# Maintainer: nnfewl <nnfewl@users.noreply.github.com>
pkgname=razer-control-bin
pkgver=0.3.0rc6
pkgrel=1
pkgdesc="Razer laptop control for Linux — fan, power, RGB, battery health. No kernel modules required."
arch=('x86_64')
url="https://github.com/nnfewl/razer-control-revived"
license=('GPL2')
depends=('dbus' 'hidapi' 'gtk4' 'libadwaita' 'libusb')
provides=('razer-control')
conflicts=('razer-control')
source=("razer-control-${pkgver/rc/-rc}-x86_64.tar.gz::https://github.com/nnfewl/razer-control-revived/releases/download/v${pkgver/rc/-rc}/razer-control-${pkgver/rc/-rc}-x86_64.tar.gz")
sha256sums=('SKIP')

package() {
    cd "razer-control-${pkgver/rc/-rc}-x86_64"

    install -Dm755 bin/razer-settings  "$pkgdir/usr/bin/razer-settings"
    install -Dm755 bin/razer-cli        "$pkgdir/usr/bin/razer-cli"
    install -Dm755 bin/daemon           "$pkgdir/usr/bin/razer-daemon"

    install -Dm644 share/razercontrol/laptops.json \
        "$pkgdir/usr/share/razercontrol/laptops.json"

    install -Dm644 share/applications/com.encomjp.razer-settings.desktop \
        "$pkgdir/usr/share/applications/com.encomjp.razer-settings.desktop"
    install -Dm644 share/icons/hicolor/scalable/apps/com.github.encomjp.razercontrol.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/com.github.encomjp.razercontrol.svg"

    install -Dm644 systemd/razercontrol.service \
        "$pkgdir/usr/lib/systemd/user/razercontrol.service"

    install -Dm644 udev/99-hidraw-permissions.rules \
        "$pkgdir/etc/udev/rules.d/99-hidraw-permissions.rules"
}
